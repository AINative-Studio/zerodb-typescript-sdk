{
  "name": "@ainative/sdk",
  "type": "module",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for AINative Studio APIs",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "docs": "typedoc --out docs src/index.ts"
  },
  "keywords": [
    "ainative",
    "api",
    "sdk",
    "typescript",
    "javascript",
    "zerodb",
    "vector-database",
    "ai",
    "agent-swarm"
  ],
  "author": "AINative Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ainative/ainative-sdk-js"
  },
  "bugs": {
    "url": "https://github.com/ainative/ainative-sdk-js/issues"
  },
  "homepage": "https://docs.ainative.studio",
  "dependencies": {
    "axios": "^1.6.2",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "rollup": "^3.29.4",
    "rollup-plugin-dts": "^5.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ]
}